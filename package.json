{
  "name": "opencode-cli-usage-meter",
  "version": "0.0.0",
  "description": "Standalone OpenCode TUI plugin that displays CLI usage in the sidebar.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/tui.js",
  "types": "./dist/tui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.2.0",
  "private": false,
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "smoke:built-package": "node -e \"await import('./dist/tui.js')\"",
    "pack:dry-run": "pnpm pack --dry-run",
    "audit:prod": "pnpm audit --prod"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.18 <2",
    "@opentui/core": ">=0.4.3 <0.5",
    "@opentui/solid": ">=0.4.3 <0.5",
    "solid-js": ">=1.9.12 <2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.18",
    "@opentui/core": "0.4.3",
    "@opentui/solid": "0.4.3",
    "@solidjs/testing-library": "^0.8.10",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild-plugin-solid": "^0.6.0",
    "jsdom": "^29.1.1",
    "solid-js": "^1.9.14",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
